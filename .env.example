# Required for live deliberation. Never commit the real key.
OPENAI_API_KEY=your_api_key_here

# The competition requires GPT-5.6. Use the explicit GPT-5.6 Sol model ID.
DISSENT_GARDEN_MODEL=gpt-5.6-sol

# Resilience controls for the live Responses API path.
DISSENT_GARDEN_API_TIMEOUT_SECONDS=90
DISSENT_GARDEN_API_MAX_RETRIES=2
